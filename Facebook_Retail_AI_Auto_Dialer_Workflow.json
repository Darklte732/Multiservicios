              "id": "business_hours_check",
              "leftValue": "={{ \n  const now = new Date();\n  const hour = now.getHours();\n  const day = now.getDay(); // 0 = Sunday, 6 = Saturday\n  \n  // Business hours: Mon-Fri 9 AM - 8 PM, Sat 10 AM - 6 PM, no Sunday calls\n  if (day === 0) return false; // No Sunday calls\n  if (day === 6) return hour >= 10 && hour < 18; // Saturday 10-6\n  return hour >= 9 && hour < 20; // Weekdays 9-8\n}}",
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            }
          ]
        },
        "combineOperation": "all"
      },
