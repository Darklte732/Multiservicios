    {
      "parameters": {
        "jsCode": "// Increment call attempt counter\nconst leadData = $node['Process Lead Data'].json.lead;\nconst callStatus = $node['Check Call Status'].json;\n\n// Update lead data with call attempt info\nconst updatedLead = {\n  ...leadData,\n  call_attempts: (leadData.call_attempts || 0) + 1,\n  last_call_time: new Date().toISOString(),\n  last_call_status: callStatus.call_status,\n  last_call_duration: callStatus.call_analysis?.duration || 0\n};\n\n// Determine next action based on attempt count\nif (updatedLead.call_attempts >= 3) {\n  updatedLead.status = 'max_attempts_reached';\n  updatedLead.next_action = 'sms_email_sequence';\n} else {\n  updatedLead.status = 'retry_pending';\n  updatedLead.next_action = 'retry_call';\n  \n  // Set next retry time (1 hour for attempt 2, 3 hours for attempt 3)\n  const hoursToWait = updatedLead.call_attempts === 1 ? 1 : 3;\n  const nextRetryTime = new Date();\n  nextRetryTime.setHours(nextRetryTime.getHours() + hoursToWait);\n  updatedLead.next_action_time = nextRetryTime.toISOString();\n}\n\nreturn { updatedLead };"
      },
