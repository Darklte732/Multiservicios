    {
      "parameters": {
        "jsCode": "// Extract and validate lead data from Facebook\nconst leadData = $input.first().json;\n\n// Extract lead information\nconst lead = {\n  id: leadData.leadgen_id || leadData.id,\n  name: '',\n  phone: '',\n  email: '',\n  form_id: leadData.form_id,\n  ad_id: leadData.ad_id,\n  campaign_id: leadData.campaign_id,\n  created_time: leadData.created_time || new Date().toISOString(),\n  source: 'facebook_lead_ad'\n};\n\n// Parse field_data array to extract name, phone, email\nif (leadData.field_data && Array.isArray(leadData.field_data)) {\n  leadData.field_data.forEach(field => {\n    const name = field.name?.toLowerCase();\n    const value = field.values?.[0] || '';\n    \n    if (name?.includes('full_name') || name?.includes('name')) {\n      lead.name = value;\n    } else if (name?.includes('phone') || name?.includes('number')) {\n      lead.phone = value.replace(/[^0-9+]/g, ''); // Clean phone number\n    } else if (name?.includes('email')) {\n      lead.email = value;\n    }\n  });\n}\n\n// Validate required fields\nif (!lead.phone) {\n  throw new Error('Phone number is required for auto-dialing');\n}\n\n// Set initial call attempt data\nlead.call_attempts = 0;\nlead.last_call_time = null;\nlead.status = 'new';\nlead.next_action_time = new Date().toISOString();\n\nreturn { lead };"
      },
      "id": "process-lead-data",
      "name": "Process Lead Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
